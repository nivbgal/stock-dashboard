# API Keys for Stock Market Data Providers

# Alpha Vantage
# Get your key: https://www.alphavantage.co/
REACT_APP_ALPHA_VANTAGE_KEY=your_key_here

# IEX Cloud
# Get your key: https://iexcloud.io/
REACT_APP_IEX_CLOUD_KEY=your_key_here

# Finnhub
# Get your key: https://finnhub.io/
REACT_APP_FINNHUB_KEY=your_key_here

# NewsAPI
# Get your key: https://newsapi.org/
REACT_APP_NEWSAPI_KEY=your_key_here

# Polygon.io
# Get your key: https://polygon.io/
REACT_APP_POLYGON_KEY=your_key_here

# Phase 3: Advanced Features

# X (Twitter) API
# Get your bearer token: https://developer.twitter.com/
REACT_APP_X_API_BEARER_TOKEN=your_bearer_token_here

# CoinGecko API (no key required for free tier)
REACT_APP_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Alternative.me Fear & Greed Index (no key required)
REACT_APP_FEAR_GREED_API_URL=https://api.alternative.me/fng/

# App Configuration
VITE_PORT=5173
VITE_API_TIMEOUT=30000

# Optional: Data refresh intervals (in milliseconds)
VITE_FEAR_GREED_REFRESH=1800000
VITE_INDICES_REFRESH=900000
VITE_CRYPTO_REFRESH=300000
VITE_TWITTER_REFRESH=600000
